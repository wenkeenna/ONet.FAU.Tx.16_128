<UserControl
    x:Class="ONet.FAU.Tx16_128.Extension.Views.ONetPDPositionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ONet.FAU.Tx16_128.Extension.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/DM.Foundation.Styles;component/Themes/Themes.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="prism:Dialog.WindowStartupLocation" Value="CenterScreen" />
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" />
                </Setter.Value>
            </Setter>
            <Setter Property="WindowStyle" Value="None" />
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ShowInTaskbar" Value="False" />
            <Setter Property="SizeToContent" Value="Manual" />
            <Setter Property="Height" Value="600" />
            <Setter Property="Width" Value="850" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Topmost" Value="True" />
            <Setter Property="ShowInTaskbar" Value="False" />
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="9*" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <!--  标题/关闭按钮  -->
        <Border
            x:Name="TitleToolList"
            Background="{StaticResource Vs2013BlueThemeColor}"
            Cursor="">
            <DockPanel LastChildFill="False">
                <Label
                    Margin="5,0,0,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Content="{Binding ToolIns.Parameter.ToolName}"
                    DockPanel.Dock="Left"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="Black" />
                <TextBlock VerticalAlignment="Center" Text="&gt;&gt;" />
                <TextBlock
                    Margin="5,0,0,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Left"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="{Binding ToolIns.Parameter.UserDefined}" />

                <Button
                    Width="30"
                    Height="20"
                    Margin="0,1,2,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Command="{Binding CancelCommand}"
                    Content="&#xe82a;"
                    Cursor="Hand"
                    DockPanel.Dock="Right"
                    FontFamily="{StaticResource MyIconfont}"
                    Foreground="Black"
                    Style="{StaticResource TitleButton}" />


            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8*" />


            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="参数">

                <StackPanel Grid.Column="0" Margin="5">

                    <Label
                        HorizontalAlignment="Left"
                        Content="用户自定义"
                        FontWeight="Bold" />
                    <TextBox
                        Height="30"
                        Margin="0,0,0,10"
                        Padding="0"
                        VerticalContentAlignment="Center"
                        Foreground="Black"
                        Text="{Binding ToolIns.Parameter.UserDefined, Mode=TwoWay}" />

                    <Label
                        HorizontalAlignment="Left"
                        Content="数据备注"
                        FontWeight="Bold" />
                    <TextBox
                        Height="30"
                        Margin="0,0,0,10"
                        Padding="0"
                        VerticalContentAlignment="Center"
                        Foreground="Black"
                        Text="{Binding ToolIns.Parameter.DataRemark, Mode=TwoWay}" />

                    <Label
                        HorizontalAlignment="Left"
                        Content="弹窗提示"
                        FontWeight="Bold" />
                    <TextBox
                        Height="50"
                        Margin="0,0,0,10"
                        Padding="0"
                        VerticalContentAlignment="Center"
                        Foreground="Black"
                        Text="{Binding ToolIns.Parameter.ToolName, Mode=TwoWay}"
                        TextWrapping="Wrap" />

                    <Label
                        HorizontalAlignment="Left"
                        Content="工具说明"
                        FontWeight="Bold" />
                    <TextBox
                        Height="50"
                        Margin="0,0,0,10"
                        Padding="0"
                        VerticalContentAlignment="Center"
                        Foreground="Black"
                        IsReadOnly="True"
                        Text="{Binding ToolIns.Parameter.ToolDescription}"
                        TextWrapping="Wrap" />
                    <CheckBox Content="弹窗提示" IsChecked="{Binding ToolIns.Parameter.IsDialogShow, Mode=TwoWay}" />
                    <CheckBox Content="是否保存数据" IsChecked="{Binding ToolIns.Parameter.IsSaveData, Mode=TwoWay}" />
                    <CheckBox Content="执行后停止" IsChecked="{Binding ToolIns.Parameter.ExecutionStop, Mode=TwoWay}" />


                </StackPanel>

            </GroupBox>

            <GroupBox Grid.Column="1" Header="配置">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*" />
                        <ColumnDefinition Width="5*" />

                    </Grid.ColumnDefinitions>
                    <GroupBox Grid.Column="0">
                        <StackPanel>
                            <GroupBox Height="140" Header="PD-A">
                                <StackPanel>
                                    <DockPanel Margin="1">
                                        <TextBlock VerticalAlignment="Center" Text="Gx:" />
                                        <TextBlock
                                            MinWidth="100"
                                            VerticalAlignment="Center"
                                            FontFamily="Green"
                                            Foreground="Green"
                                            Text="{Binding ToolIns.LeftPara.X_Str, Mode=TwoWay}" />

                                        <Button
                                            Width="50"
                                            Height="20"
                                            Command="{Binding BindingDataCommand}"
                                            CommandParameter="Str_PIC_A_X"
                                            Content="绑定"
                                            DockPanel.Dock="Right"
                                            Style="{StaticResource CommonButtonStyle}" />

                                    </DockPanel>

                                    <DockPanel Margin="1">
                                        <TextBlock Text="Gy:" />
                                        <TextBlock
                                            MinWidth="100"
                                            VerticalAlignment="Center"
                                            FontFamily="Green"
                                            Foreground="Green"
                                            Text="{Binding ToolIns.LeftPara.Y_Str, Mode=TwoWay}" />

                                        <Button
                                            Width="50"
                                            Height="20"
                                            Command="{Binding BindingDataCommand}"
                                            CommandParameter="Str_PIC_A_Y"
                                            Content="绑定"
                                            DockPanel.Dock="Right"
                                            Style="{StaticResource CommonButtonStyle}" />
                                    </DockPanel>

                                    <DockPanel Margin="1">
                                        <TextBlock Text="Cam:" />
                                        <TextBox Text="{Binding ToolIns.LeftPara.Z, Mode=TwoWay}" />
                                    </DockPanel>


                                    <DockPanel Margin="1">
                                        <TextBlock Text="亮度:" />
                                        <TextBox Text="{Binding ToolIns.LeftPara.LightValue, Mode=TwoWay}" />
                                    </DockPanel>

                                    <DockPanel Margin="1">
                                        <TextBlock Text="识别流程名:" />
                                        <TextBox Text="{Binding ToolIns.LeftPara.VisioName, Mode=TwoWay}" />
                                    </DockPanel>

                                </StackPanel>
                            </GroupBox>

                            <GroupBox Height="140" Header="PD-B">
                                <StackPanel>
                                    <DockPanel Margin="1">
                                        <TextBlock VerticalAlignment="Center" Text="Gx:" />
                                        <TextBlock
                                            MinWidth="100"
                                            VerticalAlignment="Center"
                                            FontFamily="Green"
                                            Foreground="Green"
                                            Text="{Binding ToolIns.RightPara.X_Str, Mode=TwoWay}" />

                                        <Button
                                            Width="50"
                                            Height="20"
                                            Command="{Binding BindingDataCommand}"
                                            CommandParameter="Str_PIC_B_X"
                                            Content="绑定"
                                            DockPanel.Dock="Right"
                                            Style="{StaticResource CommonButtonStyle}" />
                                    </DockPanel>

                                    <DockPanel Margin="1">

                                        <TextBlock VerticalAlignment="Center" Text="Gy:" />
                                        <TextBlock
                                            MinWidth="100"
                                            VerticalAlignment="Center"
                                            FontFamily="Green"
                                            Foreground="Green"
                                            Text="{Binding ToolIns.RightPara.Y_Str, Mode=TwoWay}" />

                                        <Button
                                            Width="50"
                                            Height="20"
                                            Command="{Binding BindingDataCommand}"
                                            CommandParameter="Str_PIC_B_Y"
                                            Content="绑定"
                                            DockPanel.Dock="Right"
                                            Style="{StaticResource CommonButtonStyle}" />
                                    </DockPanel>

                                    <DockPanel Margin="1">

                                        <TextBlock Text="Cam:" />
                                        <TextBox Text="{Binding ToolIns.RightPara.Z, Mode=TwoWay}" />
                                    </DockPanel>


                                    <DockPanel Margin="1">
                                        <TextBlock Text="亮度:" />
                                        <TextBox Text="{Binding ToolIns.RightPara.LightValue, Mode=TwoWay}" />
                                    </DockPanel>



                                    <DockPanel Margin="1">
                                        <TextBlock Text="识别流程名:" />
                                        <TextBox Text="{Binding ToolIns.RightPara.VisioName, Mode=TwoWay}" />
                                    </DockPanel>


                                </StackPanel>
                            </GroupBox>

                        </StackPanel>
                    </GroupBox>


                    <GroupBox Grid.Column="1" Header="扩展参数">
                        <StackPanel HorizontalAlignment="Center">
                            <DockPanel
                                Margin="1"
                                HorizontalAlignment="Right"
                                LastChildFill="False">
                                <TextBlock Text="速度:" />
                                <TextBox Width="100" Text="{Binding ToolIns.Speed, Mode=TwoWay}" />
                                <TextBlock Width="40" Text="mm/s" />
                            </DockPanel>

                            <DockPanel
                                Margin="1"
                                HorizontalAlignment="Right"
                                LastChildFill="False">
                                <TextBlock Text="相机安全高度:" />
                                <TextBox Width="100" Text="{Binding ToolIns.CamSafePos, Mode=TwoWay}" />
                                <TextBlock Width="40" Text="mm" />
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                </Grid>
            </GroupBox>
        </Grid>

        <!--  底部菜单栏 确认/取消  -->
        <Border Grid.Row="2">
            <DockPanel Margin="2" LastChildFill="False">
                <Button
                    Width="80"
                    Margin="0,0,10,5"
                    Command="{Binding ConfirmCommand}"
                    Content="确认"
                    DockPanel.Dock="Right"
                    Style="{StaticResource WinFormsButtonStyle}" />
                <Button
                    Width="80"
                    Margin="0,0,10,5"
                    Command="{Binding CancelCommand}"
                    Content="取消"
                    DockPanel.Dock="Right"
                    Style="{StaticResource WinFormsButtonStyle}" />
            </DockPanel>
        </Border>


    </Grid>
</UserControl>
