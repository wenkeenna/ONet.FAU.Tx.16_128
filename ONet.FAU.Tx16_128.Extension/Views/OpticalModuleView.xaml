<UserControl
    x:Class="ONet.FAU.Tx16_128.Extension.Views.OpticalModuleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:ONet.FAU.Tx16_128.Extension.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ONet.FAU.Tx16_128.Extension.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="350"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/DM.Foundation.Styles;component/Themes/Themes.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converter:EnumToBooleanConverter x:Key="EnumConverter" />
            <converter:ChIndexToNameConverter x:Key="ChIndexToNameConverter" />

        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border
            Margin="2"
            Background="#F5F5F5"
            BorderBrush="#333"
            BorderThickness="1"
            CornerRadius="3">
            <StackPanel Margin="5">
                <Grid Margin="0,0,0,5">
                    <Border
                        Padding="6,2"
                        HorizontalAlignment="Left"
                        Background="DarkMagenta"
                        CornerRadius="2">
                        <TextBlock
                            FontSize="11"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="光模块8通道[ADC]" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        FontSize="10"
                        FontStyle="Italic"
                        Foreground="Gray"
                        Text="Current Acquisition Unit" />
                </Grid>

                <!--  八组选项  -->
                <Border
                    Margin="0,0,0,8"
                    Padding="8,6"
                    Background="White"
                    BorderBrush="#CCC"
                    BorderThickness="1"
                    CornerRadius="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!--<TextBlock
                            VerticalAlignment="Center"
                            FontSize="10"
                            FontWeight="Bold"
                            Foreground="#666"
                            Text="通道组：" />-->
                        <StackPanel Grid.Column="1">
                            <!--<RadioButton
                                Margin="2"
                                VerticalContentAlignment="Center"
                                Content="组1/2"
                                FontSize="10"
                                GroupName="ChannelGroup"
                                IsChecked="{Binding SelectedGroup, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group1}, Mode=TwoWay}" />
                            <RadioButton
                               Margin="10 2 2 2"
                                VerticalContentAlignment="Center"
                                Content="组3/4"
                                FontSize="10"
                                GroupName="ChannelGroup"
                                IsChecked="{Binding SelectedGroup, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group2}, Mode=TwoWay}" />
                            <RadioButton
                                Margin="10 2 2 2"
                                VerticalContentAlignment="Center"
                                Content="组5/6"
                                FontSize="10"
                                GroupName="ChannelGroup"
                                IsChecked="{Binding SelectedGroup, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group3}, Mode=TwoWay}" />
                            <RadioButton
                                Margin="10 2 2 2"

                                VerticalContentAlignment="Center"
                                Content="组7/8"
                                FontSize="10"
                                GroupName="ChannelGroup"
                                IsChecked="{Binding SelectedGroup, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group4}, Mode=TwoWay}" />-->
                            <TextBlock Text="通道组A：" />
                            <DockPanel>
                                <RadioButton
                                    Content="组1[0-7]"
                                    GroupName="ChannelGroupA"
                                    IsChecked="{Binding SelectedGroupA, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group1}, Mode=TwoWay}" />
                                <RadioButton
                                    Margin="5,0,0,0"
                                    Content="组2[8-15]"
                                    GroupName="ChannelGroupA"
                                    IsChecked="{Binding SelectedGroupA, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group2}, Mode=TwoWay}" />
                                <RadioButton
                                    Margin="5,0,0,0"
                                    Content="组3[16-23]"
                                    GroupName="ChannelGroupA"
                                    IsChecked="{Binding SelectedGroupA, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group3}, Mode=TwoWay}" />
                                <RadioButton
                                    Margin="5,0,0,0"
                                    Content="组4[24-31]"
                                    GroupName="ChannelGroupA"
                                    IsChecked="{Binding SelectedGroupA, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group4}, Mode=TwoWay}" />
                            </DockPanel>

                            <TextBlock Text="通道组B：" />
                            <DockPanel>
                                <RadioButton
                                    Content="组1[0-7]"
                                    GroupName="ChannelGroupB"
                                    IsChecked="{Binding SelectedGroupB, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group1}, Mode=TwoWay}" />

                                <RadioButton
                                    Margin="5,0,0,0"
                                    Content="组2[8-15]"
                                    GroupName="ChannelGroupB"
                                    IsChecked="{Binding SelectedGroupB, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group2}, Mode=TwoWay}" />
                                <RadioButton
                                    Margin="5,0,0,0"
                                    Content="组3[16-23]"
                                    GroupName="ChannelGroupB"
                                    IsChecked="{Binding SelectedGroupB, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group3}, Mode=TwoWay}" />
                                <RadioButton
                                    Margin="5,0,0,0"
                                    Content="组4[24-31]"
                                    GroupName="ChannelGroupB"
                                    IsChecked="{Binding SelectedGroupB, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static converter:ChannelGroup.Group4}, Mode=TwoWay}" />

                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid MinHeight="200">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <GroupBox
                        Grid.Column="0"
                        BorderBrush="{StaticResource Color.Accent.Blue}"
                        BorderThickness="2"
                        Header="ADC[L]">
                        <StackPanel>
                            <!--  CH1  -->
                            <!--<Border
                                Margin="2"
                                Padding="3"
                                Background="White"
                                BorderBrush="#CCC"
                                BorderThickness="1"
                                CornerRadius="2">
                                <DockPanel>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="8"
                                        FontWeight="Bold"
                                        Foreground="#666"
                                        Text="CH1" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Foreground="{Binding AdcChannels[0].StatusColor, FallbackValue=Gray}"
                                        Text="{Binding AdcChannels[0].Current, FallbackValue=0.0000, StringFormat={}{0:F4}}" />
                                </DockPanel>
                            </Border>-->
                            <ItemsControl AlternationCount="8" ItemsSource="{Binding AdcChannelsA}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="2"
                                            Padding="3"
                                            Background="White"
                                            BorderBrush="#CCC"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                            <DockPanel>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="8"
                                                    FontWeight="Bold"
                                                    Foreground="#666"
                                                    Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=Tag, Converter={StaticResource ChIndexToNameConverter}}" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="22"
                                                    FontWeight="Bold"
                                                    Foreground="{Binding StatusColor, FallbackValue=Gray}"
                                                    Text="{Binding Current, FallbackValue=0.0000, StringFormat={}{0:F4}}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                    </GroupBox>



                    <GroupBox
                        Grid.Column="1"
                        BorderBrush="{StaticResource Color.Accent.Blue}"
                        BorderThickness="2"
                        Header="ADC[R]">
                        <StackPanel>
                            <!--<Border
                                Margin="2"
                                Padding="3"
                                Background="White"
                                BorderBrush="#CCC"
                                BorderThickness="1"
                                CornerRadius="2">
                                <DockPanel>
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="8"
                                        FontWeight="Bold"
                                        Foreground="#666"
                                        Text="CH1" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Foreground="{Binding AdcChannels[4].StatusColor, FallbackValue=Gray}"
                                        Text="{Binding AdcChannels[4].Current, FallbackValue=0.0000, StringFormat={}{0:F4}}" />
                                </DockPanel>
                            </Border>-->

                            <ItemsControl AlternationCount="8" ItemsSource="{Binding AdcChannelsB}">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Tag" Value="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="2"
                                            Padding="3"
                                            Background="White"
                                            BorderBrush="#CCC"
                                            BorderThickness="1"
                                            CornerRadius="2">
                                            <DockPanel>
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="8"
                                                    FontWeight="Bold"
                                                    Foreground="#666"
                                                    Text="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=Tag, Converter={StaticResource ChIndexToNameConverter}}" />
                                                <TextBlock
                                                    HorizontalAlignment="Center"
                                                    FontSize="22"
                                                    FontWeight="Bold"
                                                    Foreground="{Binding StatusColor, FallbackValue=Gray}"
                                                    Text="{Binding Current, FallbackValue=0.0000, StringFormat={}{0:F4}}" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>


                        </StackPanel>

                    </GroupBox>
                </Grid>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
